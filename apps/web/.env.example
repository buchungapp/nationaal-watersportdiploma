NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY="supabase status"
SUPABASE_SERVICE_ROLE_KEY="supabase status"
PGURI="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Better Auth (email OTP) — replaces Supabase Auth for sign-in
BETTER_AUTH_SECRET="$(openssl rand -base64 32)"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_TRUSTED_ORIGINS="http://localhost:3000"
RESEND_API_KEY="re_..."
AUTH_EMAIL_FROM="NWD <auth@nationaalwatersportdiploma.nl>"
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY="EMPTY"
POSTHOG_API_KEY="EMPTY"
# Feature flag for server-side LLM-call telemetry (captureAiTurn +
# flushAiTelemetry). Set to "1" in production so AI events start
# landing in PostHog; leave unset in dev so local iteration doesn't
# pollute prod dashboards.
POSTHOG_AI_TELEMETRY="0"
# Local dev: start the redis service from the repo-root docker-compose.yml
# (`docker compose up -d redis`) and use the URL below. In production we
# use Upstash over TLS/TCP — replace with the rediss:// URL from the
# Upstash dashboard, unchanged from what ioredis already expects.
REDIS_URL="redis://localhost:6379"
FLAGS_SECRET='node -e "console.log(crypto.randomBytes(32).toString('base64url'))"'
AXIOM_OTEL_DATASET_NAME="nwd-otel-dev"
AXIOM_API_KEY="your-axiom-api-key"

# Portfolio helper sandbox (Phase 1 — local dev only, not yet used in production routes).
# The sandbox + the corpus anonymiser both go through Vercel AI Gateway so we
# get unified logging, spend controls, and provider routing in one place.
AI_GATEWAY_API_KEY="vck_..."

# Upstash QStash — powers the durable portfolio-ingest workflow
# (apps/web/src/app/api/workflow/ingest-portfolio/route.ts).
#
# Local dev: run `pnpm dev:qstash` in a sidecar terminal. The CLI
# starts an in-memory QStash server on :8080 and prints four sets of
# test credentials. Pick the first one for these three env vars; the
# server restart resets state, so treat it as ephemeral.
#
# Production: create a QStash project at https://console.upstash.com/qstash
# and paste the token + signing keys from the dashboard. Point
# QSTASH_URL at https://qstash.upstash.io (the default, can be
# omitted in prod).
QSTASH_URL="http://127.0.0.1:8080"
QSTASH_TOKEN="eyJVc2VySUQiOiJkZWZhdWx0VXNlciIsIlBhc3N3b3JkIjoiZGVmYXVsdFBhc3N3b3JkIn0="

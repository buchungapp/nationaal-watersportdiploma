{
  "extends": "@tsconfig/node22",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./out",
    "noUncheckedIndexedAccess": true,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "lib": ["ESNext", "DOM"],
    "composite": false,
    "declaration": false
  },
  "include": ["src/**/*"]
}

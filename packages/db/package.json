{
  "name": "@nawadi/db",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "default": "./src/main.ts"
    },
    "./drizzle": {
      "types": "./src/lib/drizzle.ts",
      "default": "./src/lib/drizzle.ts"
    }
  },
  "scripts": {
    "amend": "drizzle-kit drop && drizzle-kit generate",
    "prepack": "tsc --build",
    "build": "tsc --build",
    "dev": "tsc --noEmit --watch",
    "watch": "tsc --noEmit --watch",
    "clean": "rm -rf out && tsc --build --clean",
    "test": "tsx --tsconfig ../../tsconfig.source-runtime.json --test './src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "generate:custom": "drizzle-kit generate --custom",
    "generate:schema": "drizzle-kit generate",
    "up": "drizzle-kit up",
    "generate:all": "sh './src/generate-migrations.sh'",
    "generate:clean": "rm -rf ./migrations && pnpm run generate:all",
    "drop": "drizzle-kit drop",
    "execute-migration": "tsx --tsconfig ../../tsconfig.source-runtime.json ./src/program.ts migrate"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:buchungapp/nationaal-watersportdiploma.git"
  },
  "author": "",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/buchungapp/nationaal-watersportdiploma/issues"
  },
  "keywords": [],
  "dependencies": {
    "@types/node": "catalog:",
    "@types/yargs": "17.0.35",
    "drizzle-orm": "catalog:",
    "tslib": "2.8.1",
    "type-fest": "4.37.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "tsx": "4.19.4",
    "@types/pg": "catalog:",
    "pg": "catalog:"
  }
}

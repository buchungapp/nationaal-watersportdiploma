{
  "extends": "@tsconfig/node22",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noUncheckedIndexedAccess": true,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts"]
}

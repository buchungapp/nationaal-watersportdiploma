{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "nodenext",
    "moduleResolution": "node16",
    "target": "es2024",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["**/node_modules/**", ".turbo"]
}
